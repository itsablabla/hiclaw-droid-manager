+++ b/droid-manager/Dockerfile
@@ -0,0 +1,80 @@
+# ============================================================
+# HiClaw Manager — Droid Runtime
+# ============================================================
+# Lightweight Python image with the Factory.ai Droid CLI baked in, plus the
+# matrix-nio[e2e] runtime needed to bridge Matrix to droid exec.
+#
+# This image is the equivalent of hiclaw-manager-copaw, but for the Droid
+# Factory CLI runtime. It is wired into the HiClaw Manager when
+# HICLAW_MANAGER_RUNTIME=droid (see start-manager-agent.sh).
+#
+# Build args mirror the other HiClaw images:
+#   HIGRESS_REGISTRY  - base image registry (default: cn-hangzhou)
+#   APT_MIRROR        - APT mirror host (default: empty)
+#   DROID_VERSION     - droid CLI version pin (default: latest)
+# ============================================================
+
+ARG HIGRESS_REGISTRY=higress-registry.cn-hangzhou.cr.aliyuncs.com
+FROM ${HIGRESS_REGISTRY}/higress/ubuntu:24.04
+
+ARG APT_MIRROR=
+ARG DROID_VERSION=latest
+ARG HTTP_PROXY
+ARG HTTPS_PROXY
+
+ENV HTTP_PROXY=${HTTP_PROXY} \
+    HTTPS_PROXY=${HTTPS_PROXY} \
+    DEBIAN_FRONTEND=noninteractive
+
+RUN if [ -n "${APT_MIRROR}" ]; then \
+        for _src in /etc/apt/sources.list /etc/apt/sources.list.d/ubuntu.sources; do \
+            [ -f "${_src}" ] && sed -i \
+                "s|archive.ubuntu.com|${APT_MIRROR}|g; \
+                 s|security.ubuntu.com|${APT_MIRROR}|g; \
+                 s|ports.ubuntu.com|${APT_MIRROR}|g" "${_src}" || true; \
+        done; \
+    fi && \
+    apt-get update && apt-get install -y --no-install-recommends \
+        python3 python3-pip python3-venv \
+        curl ca-certificates jq gettext-base \
+        git openssh-client procps tzdata \
+        libolm3 \
+    && rm -rf /var/lib/apt/lists/*
+
+# Install Node.js 22 — needed for `npm install -g droid` (smaller than the
+# curl-piped installer and lets us pin DROID_VERSION).
+RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
+    apt-get install -y --no-install-recommends nodejs && \
+    rm -rf /var/lib/apt/lists/*
+
+# Install the Factory CLI
+ARG DROID_VERSION
+ENV DROID_VERSION=${DROID_VERSION}
+COPY scripts/install-droid-cli.sh /usr/local/bin/install-droid-cli.sh
+RUN chmod +x /usr/local/bin/install-droid-cli.sh && /usr/local/bin/install-droid-cli.sh
+
+# Copy the droid-manager Python package
+WORKDIR /opt/hiclaw/droid-manager
+COPY pyproject.toml README.md ./
+COPY src ./src
+COPY scripts ./scripts
+
+# Install droid-manager and its runtime deps
+RUN python3 -m pip install --no-cache-dir --break-system-packages \
+        ".[test]"==0.1.0 || \
+    python3 -m pip install --no-cache-dir --break-system-packages "."
+
+# Symlinks so supervisord can call our scripts on the canonical paths.
+RUN install -m 0755 scripts/start-droid-manager.sh \
+        /opt/hiclaw/scripts/init/start-droid-manager.sh && \
+    chmod +x /opt/hiclaw/scripts/init/start-droid-manager.sh
+
+ENV PYTHONUNBUFFERED=1 \
+    PYTHONPATH=/opt/hiclaw/droid-manager/src \
+    HICLAW_MANAGER_RUNTIME=droid
+
+# Clear build-only proxy env so curl in the container talks to localhost
+# directly at runtime.
+ENV HTTP_PROXY= HTTPS_PROXY=
+
+ENTRYPOINT ["/opt/hiclaw/scripts/init/start-droid-manager.sh"]
